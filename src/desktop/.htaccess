<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^config\.json$ - [F,L]
  RewriteRule ^config\.example\.json$ - [F,L]
  RewriteRule ^main\.py$ - [F,L]
  RewriteRule ^passenger_wsgi\.py$ - [F,L]
  RewriteRule ^requirements.*\.txt$ - [F,L]
  RewriteRule ^\.env$ - [F,L]
  RewriteRule ^\.gitignore$ - [F,L]
  RewriteRule ^\.htaccess$ - [F,L]
  RewriteRule ^secrets/ - [F,L]
  RewriteRule ^__pycache__/ - [F,L]
  RewriteRule \.db$ - [F,L]
  RewriteRule \.db-journal$ - [F,L]
  RewriteRule \.log$ - [F,L]
  RewriteRule \.pyc$ - [F,L]
  RewriteRule virtualenv/ - [F,L]
  RewriteRule venv/ - [F,L]
</IfModule>

<FilesMatch "\.(py|db|env|log|pyc|db-journal)$">
  Require all denied
</FilesMatch>

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
