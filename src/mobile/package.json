{
  "name": "simplemail-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "Wrapper natif Capacitor pour SimpleMail (Android .apk + iOS .ipa)",
  "scripts": {
    "add:android": "npx cap add android",
    "add:ios": "npx cap add ios",
    "sync": "npx cap sync",
    "build:android": "npx cap sync android && cd android && ./gradlew assembleDebug",
    "open:android": "npx cap open android",
    "open:ios": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.0",
    "@capacitor/core": "^6.1.0",
    "@capacitor/ios": "^6.1.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.0"
  }
}
